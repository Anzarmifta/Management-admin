<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MTC.SYS — Repair Logs & Analytics</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --bg-body: #f8fafc;
            --card-bg: #ffffff;
            --border-color: #f1f5f9;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --radius-ios: 16px;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            -webkit-font-smoothing: antialiased;
        }

        .navbar {
            background: rgba(255, 255, 255, 0.85) !important;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid #e2e8f0;
        }
        .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.5px;
            color: #0f172a !important;
        }

        .ios-card {
            background: var(--card-bg);
            border: 1px solid #e2e8f0;
            border-radius: var(--radius-ios);
            box-shadow: 0 4px 20px rgba(15, 23, 42, 0.02);
        }

        .form-control, .form-select {
            border-radius: 10px;
            padding: 10px 14px;
            border: 1px solid #cbd5e1;
            background-color: #ffffff;
            font-size: 0.875rem;
            transition: all 0.2s ease;
        }
        .form-control:focus, .form-select:focus {
            border-color: #0f172a;
            box-shadow: 0 0 0 3px rgba(15, 23, 42, 0.05);
        }

        .btn {
            border-radius: 10px;
            padding: 9px 14px;
            font-weight: 600;
            font-size: 0.85rem;
            transition: all 0.2s;
        }
        .btn-dark {
            background-color: #0f172a;
            border: none;
        }
        .btn-dark:hover {
            background-color: #1e293b;
        }
        .btn-light-subtle {
            background-color: #f1f5f9;
            color: #334155;
            border: 1px solid #e2e8f0;
        }
        .btn-light-subtle:hover {
            background-color: #e2e8f0;
            color: #0f172a;
        }

        .offcanvas {
            border-top-right-radius: 24px;
            border-bottom-right-radius: 24px;
            border: none;
            box-shadow: 10px 0 40px rgba(15, 23, 42, 0.1);
        }
        .offcanvas-header { padding: 24px 24px 10px 24px; }
        .offcanvas-body { padding: 20px 24px; }
        .sidebar-item {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            border-radius: 12px;
            color: var(--text-muted);
            font-weight: 500;
            text-decoration: none;
            margin-bottom: 6px;
            transition: all 0.2s;
        }
        .sidebar-item:hover, .sidebar-item.active {
            background-color: #f1f5f9;
            color: var(--text-main);
        }

        .table {
            color: var(--text-main);
            white-space: nowrap;
            margin-bottom: 0;
        }
        .table > thead > tr > th {
            background-color: #f8fafc;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid #e2e8f0;
            padding: 12px 14px;
        }
        .table > tbody > tr > td {
            padding: 12px 14px;
            font-size: 0.85rem;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        .modal-content {
            border: none;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.1);
        }
        .modal-header, .modal-footer {
            border-color: #f1f5f9;
            padding: 18px 20px;
        }
        .modal-body { padding: 20px; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand px-4 sticky-top">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-light-subtle d-flex align-items-center justify-content-center p-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#leftSidebar" aria-controls="leftSidebar" style="width: 38px; height: 38px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-list" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z"/>
                </svg>
            </button>
            <span class="navbar-brand mb-0 h1">MTC.SYS</span>
        </div>
        <div class="navbar-nav ms-auto align-items-center">
            <span class="text-muted small d-none d-sm-inline">Admin Panel</span>
        </div>
    </nav>

    <div class="offcanvas offcanvas-start" tabindex="-1" id="leftSidebar" aria-labelledby="leftSidebarLabel" style="width: 280px;">
        <div class="offcanvas-header border-0 pb-0">
            <h5 class="offcanvas-title fw-bold" id="leftSidebarLabel">MTC.SYS</h5>
            <button type="button" class="btn-close shadow-none" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column justify-content-between">
            <div>
                <p class="text-muted small mb-3 px-2">Menu Navigasi</p>
                <div class="list-unstyled">
                    <a href="/admin/sparepart" class="sidebar-item">Sparepart Inventory</a>
                    <a href="/admin/repair" class="sidebar-item active">Repair Logs</a>
                    <a href="/admin/users" class="sidebar-item">Manajemen Akun</a>
                </div>
            </div>
            <div class="pt-3 border-top">
                <a href="/logout" class="sidebar-item text-danger">Logout</a>
            </div>
        </div>
    </div>

    <div class="container my-4">
        
        <div class="row g-4 mb-4">
            <div class="col-12">
                <div class="ios-card p-4 h-100">
                    <h6 class="fw-bold mb-3">Export Laporan Perbaikan</h6>
                    <form action="/admin/repair/export" method="GET" class="row g-2">
                        <div class="col-12 col-sm-4">
                            <input type="date" name="startDate" class="form-control" required>
                        </div>
                        <div class="col-12 col-sm-4">
                            <input type="date" name="endDate" class="form-control" required>
                        </div>
                        <div class="col-12 col-sm-4">
                            <button type="submit" class="btn btn-light-subtle text-success w-100 fw-semibold">Download Excel</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Bagian Diagram: Diagram Lingkaran Top 3 & Bar Chart Durasi -->
        <div class="row g-4 mb-4">
            <div class="col-12 col-md-6">
                <div class="ios-card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0" style="letter-spacing: -0.5px;">Top 3 Mesin Terbanyak Repair</h5>
                        <span class="text-muted small">Diagram Lingkaran</span>
                    </div>
                    <div style="position: relative; height: 260px; width: 100%; display: flex; justify-content: center; align-items: center;">
                        <canvas id="topMachinesPieChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6">
                <div class="ios-card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0" style="letter-spacing: -0.5px;">Durasi Waktu Perbaikan</h5>
                        <span class="text-muted small">Total Menit per Mesin</span>
                    </div>
                    <div style="position: relative; height: 260px; width: 100%;">
                        <canvas id="repairAnalyticsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="ios-card p-4 mb-4">
            <h6 class="fw-bold mb-3">Sortir & Filter Laporan</h6>
            <form action="/admin/repair" method="GET" class="row g-3 align-items-end">
                <input type="hidden" name="filterType" value="<%= typeof filterType !== 'undefined' ? filterType : 'all' %>" id="filterTypeInput">
                
                <div class="col-12 col-md-3">
                    <label class="form-label text-muted small fw-semibold">Cari Nama Mesin:</label>
                    <input type="text" name="namaMesin" class="form-control" placeholder="Ketik nama mesin..." value="<%= typeof namaMesin !== 'undefined' ? namaMesin : '' %>">
                </div>

                <div class="col-12 col-md-2">
                    <label class="form-label text-muted small fw-semibold">Metode Filter:</label>
                    <select id="selectorType" class="form-select" onchange="toggleFilter(this.value)">
                        <option value="all" <%= (typeof filterType !== 'undefined' && filterType=='all')?'selected':'' %>>Semua</option>
                        <option value="date" <%= (typeof filterType !== 'undefined' && filterType=='date')?'selected':'' %>>Tanggal Spesifik</option>
                        <option value="month" <%= (typeof filterType !== 'undefined' && filterType=='month')?'selected':'' %>>Bulan & Tahun</option>
                        <option value="year" <%= (typeof filterType !== 'undefined' && filterType=='year')?'selected':'' %>>Tahun Saja</option>
                        <option value="week" <%= (typeof filterType !== 'undefined' && filterType=='week')?'selected':'' %>>Rentang (Minggu)</option>
                    </select>
                </div>

                <div class="col-12 col-md-2" id="dateBox" style="display: <%= (typeof filterType !== 'undefined' && filterType=='date')?'block':'none' %>;">
                    <label class="form-label text-muted small fw-semibold">Tanggal</label>
                    <input type="date" name="tanggalFilter" class="form-control" value="<%= typeof tanggalFilter !== 'undefined' ? tanggalFilter : '' %>">
                </div>

                <div class="col-12 col-md-2" id="monthBox" style="display: <%= (typeof filterType !== 'undefined' && filterType=='month')?'block':'none' %>;">
                    <label class="form-label text-muted small fw-semibold">Bulan</label>
                    <input type="month" name="month" class="form-control" value="<%= typeof month !== 'undefined' ? month : '' %>">
                </div>

                <div class="col-12 col-md-2" id="yearBox" style="display: <%= (typeof filterType !== 'undefined' && filterType=='year')?'block':'none' %>;">
                    <label class="form-label text-muted small fw-semibold">Tahun</label>
                    <input type="number" name="year" class="form-control" placeholder="Contoh: 2026" value="<%= typeof year !== 'undefined' ? year : '' %>">
                </div>

                <div class="col-12 col-md-2" id="weekStartBox" style="display: <%= (typeof filterType !== 'undefined' && filterType=='week')?'block':'none' %>;">
                    <label class="form-label text-muted small fw-semibold">Dari Tanggal</label>
                    <input type="date" name="weekStart" class="form-control" value="<%= typeof weekStart !== 'undefined' ? weekStart : '' %>">
                </div>
                <div class="col-12 col-md-2" id="weekEndBox" style="display: <%= (typeof filterType !== 'undefined' && filterType=='week')?'block':'none' %>;">
                    <label class="form-label text-muted small fw-semibold">Sampai Tanggal</label>
                    <input type="date" name="weekEnd" class="form-control" value="<%= typeof weekEnd !== 'undefined' ? weekEnd : '' %>">
                </div>

                <div class="col-12 col-md-3">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-dark w-100">Terapkan</button>
                        <a href="/admin/repair" class="btn btn-light-subtle text-danger">Reset</a>
                    </div>
                </div>
            </form>
        </div>

        <div class="ios-card p-4">
            <h5 class="fw-bold mb-3" style="letter-spacing: -0.5px;">Daftar Kegiatan Perbaikan</h5>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Tanggal</th>
                            <th>Shift</th>
                            <th>Mesin</th>
                            <th>Problem</th>
                            <th>Analisa</th>
                            <th>Perbaikan</th>
                            <th>Sparepart Dipakai</th>
                            <th>PIC</th>
                            <th>Jam</th>
                            <th>Status</th>
                            <th>Ket</th>
                            <th>Aksi Admin</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(repairs.length === 0) { %>
                            <tr><td colspan="12" class="text-center py-4 text-muted">Belum ada data perbaikan ditemukan.</td></tr>
                        <% } %>
                        <% repairs.forEach(r => { %>
                        <tr>
                            <td class="fw-semibold text-secondary"><%= r.tanggal ? r.tanggal.toISOString().split('T')[0] : '' %></td>
                            <td><%= r.shift %></td>
                            <td class="fw-bold text-dark"><%= r.namaMesin %></td>
                            <td><%= r.problem %></td>
                            <td><%= r.analisaPenyebab %></td>
                            <td><%= r.caraPerbaikan %></td>
                            <td>
                                <% if(r.sparepartsUsed && r.sparepartsUsed.length > 0) { %>
                                    <ul class="ps-3 mb-0">
                                        <% r.sparepartsUsed.forEach(item => { %>
                                            <li><%= item.sparepart ? item.sparepart.namaBarang : 'Dihapus' %> (<%= item.jumlahPakai %>x)</li>
                                        <% }) %>
                                    </ul>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                            <td><%= r.pic %></td>
                            <td><%= r.jamMulai %> - <%= r.jamSelesai %></td>
                            <td>
                                <span class="badge bg-<%= r.status=='ok'?'success':(r.status=='progress'?'warning':'danger') %> px-2 py-1 rounded-pill fw-medium">
                                    <%= r.status.toUpperCase() %>
                                </span>
                            </td>
                            <td><%= r.keterangan || '-' %></td>
                            <td>
                                <button type="button" class="btn btn-sm btn-light-subtle text-dark fw-semibold" onclick="openStatusModal('<%= r._id %>', '<%= r.status %>')">
                                    Ubah Status
                                </button>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <nav class="mt-4">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                        <a class="page-link border-0 text-dark fw-semibold bg-light rounded-start-pill px-3" href="/admin/repair?page=<%= currentPage - 1 %>&filterType=<%= filterType %>">Previous</a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link border-0 bg-transparent text-muted">Halaman <%= currentPage %> dari <%= totalPages %></span>
                    </li>
                    <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                        <a class="page-link border-0 text-dark fw-semibold bg-light rounded-end-pill px-3" href="/admin/repair?page=<%= currentPage + 1 %>&filterType=<%= filterType %>">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>

    <!-- Modal Ubah Status -->
    <div class="modal fade" id="statusModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 380px;">
            <div class="modal-content border-0 p-3">
                <form id="updateStatusForm" method="POST">
                    <div class="modal-body">
                        <h5 class="fw-bold mb-3">Ubah Status Perbaikan</h5>
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-semibold">Pilih Status Baru:</label>
                            <select name="status" id="modalStatusSelect" class="form-select" required>
                                <option value="open">Open</option>
                                <option value="progress">Progress</option>
                                <option value="ok">OK</option>
                            </select>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-dark w-100 py-2">Simpan Perubahan</button>
                            <button type="button" class="btn btn-light-subtle w-100 py-2" data-bs-dismiss="modal">Batal</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function toggleFilter(val) {
            document.getElementById('filterTypeInput').value = val;
            document.getElementById('dateBox').style.display = val === 'date' ? 'block' : 'none';
            document.getElementById('monthBox').style.display = val === 'month' ? 'block' : 'none';
            document.getElementById('yearBox').style.display = val === 'year' ? 'block' : 'none';
            document.getElementById('weekStartBox').style.display = val === 'week' ? 'block' : 'none';
            document.getElementById('weekEndBox').style.display = val === 'week' ? 'block' : 'none';
        }

        function openStatusModal(repairId, currentStatus) {
            const form = document.getElementById('updateStatusForm');
            form.action = '/admin/repair/status/' + repairId;
            document.getElementById('modalStatusSelect').value = currentStatus;
            new bootstrap.Modal(document.getElementById('statusModal')).show();
        }

        // Processing machine statistics
        const machineStats = {};
        <% repairs.forEach(r => { %>
            const mName = "<%= r.namaMesin %>";
            let durationMinutes = 30;
            try {
                const startParts = "<%= r.jamMulai %>".split(':');
                const endParts = "<%= r.jamSelesai %>".split(':');
                const startMin = parseInt(startParts[0]) * 60 + parseInt(startParts[1]);
                const endMin = parseInt(endParts[0]) * 60 + parseInt(endParts[1]);
                let diff = endMin - startMin;
                if(diff > 0) durationMinutes = diff;
            } catch(e) {}

            if(!machineStats[mName]) {
                machineStats[mName] = { count: 0, duration: 0 };
            }
            machineStats[mName].count += 1;
            machineStats[mName].duration += durationMinutes;
        <% }) %>

        // Sort machines by frequency descending to get Top 3
        const sortedMachines = Object.keys(machineStats).sort((a, b) => machineStats[b].count - machineStats[a].count);
        
        let topLabels = [];
        let topCounts = [];
        
        if (sortedMachines.length <= 3) {
            topLabels = sortedMachines;
            topCounts = sortedMachines.map(m => machineStats[m].count);
        } else {
            topLabels = sortedMachines.slice(0, 3);
            topCounts = topLabels.map(m => machineStats[m].count);
            
            // Calculate "Lainnya" untuk mesin peringkat ke-4 dan seterusnya
            let otherCount = 0;
            for (let i = 3; i < sortedMachines.length; i++) {
                otherCount += machineStats[sortedMachines[i]].count;
            }
            topLabels.push('Lainnya');
            topCounts.push(otherCount);
        }

        // 1. Pie Chart for Top 3 Machines
        const pieCtx = document.getElementById('topMachinesPieChart').getContext('2d');
        new Chart(pieCtx, {
            type: 'pie',
            data: {
                labels: topLabels.length > 0 ? topLabels : ['Tidak Ada Data'],
                datasets: [{
                    data: topCounts.length > 0 ? topCounts : [1],
                    backgroundColor: ['#0f172a', '#38bdf8', '#cbd5e1', '#94a3b8'],
                    borderWidth: 2,
                    borderColor: '#ffffff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });

        // 2. Bar Chart for Duration
        const allLabels = Object.keys(machineStats);
        const dataDurations = allLabels.map(l => machineStats[l].duration);

        const ctx = document.getElementById('repairAnalyticsChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: allLabels.length > 0 ? allLabels : ['Tidak Ada Data'],
                datasets: [{
                    label: 'Total Waktu Perbaikan (Menit)',
                    data: dataDurations.length > 0 ? dataDurations : [0],
                    backgroundColor: '#0f172a',
                    borderRadius: 8,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'top' }
                },
                scales: {
                    y: { 
                        beginAtZero: true, 
                        grid: { color: '#f1f5f9' },
                        title: { display: true, text: 'Menit' }
                    },
                    x: { grid: { display: false } }
                }
            }
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
