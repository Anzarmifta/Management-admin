<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MTC.SYS — Sparepart</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --bg-body: #f8fafc;
            --card-bg: #ffffff;
            --border-color: #f1f5f9;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --radius-ios: 16px;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            -webkit-font-smoothing: antialiased;
        }

        /* Navbar Clean Glassmorphism */
        .navbar {
            background: rgba(255, 255, 255, 0.85) !important;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid #e2e8f0;
        }
        .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.5px;
            color: #0f172a !important;
        }

        /* Card Container */
        .ios-card {
            background: var(--card-bg);
            border: 1px solid #e2e8f0;
            border-radius: var(--radius-ios);
            box-shadow: 0 4px 20px rgba(15, 23, 42, 0.02);
        }

        /* Form Controls & Inputs */
        .form-control, .form-select {
            border-radius: 10px;
            padding: 10px 14px;
            border: 1px solid #cbd5e1;
            background-color: #ffffff;
            font-size: 0.875rem;
            transition: all 0.2s ease;
        }
        .form-control:focus, .form-select:focus {
            border-color: #0f172a;
            box-shadow: 0 0 0 3px rgba(15, 23, 42, 0.05);
        }

        /* Buttons Style */
        .btn {
            border-radius: 10px;
            padding: 8px 14px;
            font-weight: 600;
            font-size: 0.85rem;
            transition: all 0.2s;
        }
        .btn-dark {
            background-color: #0f172a;
            border: none;
        }
        .btn-dark:hover {
            background-color: #1e293b;
        }
        .btn-light-subtle {
            background-color: #f1f5f9;
            color: #334155;
            border: 1px solid #e2e8f0;
        }
        .btn-light-subtle:hover {
            background-color: #e2e8f0;
            color: #0f172a;
        }

        /* Offcanvas Sidebar Kiri ala iOS */
        .offcanvas {
            border-top-right-radius: 24px;
            border-bottom-right-radius: 24px;
            border: none;
            box-shadow: 10px 0 40px rgba(15, 23, 42, 0.1);
        }
        .offcanvas-header {
            padding: 24px 24px 10px 24px;
        }
        .offcanvas-body {
            padding: 20px 24px;
        }
        .sidebar-item {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            border-radius: 12px;
            color: var(--text-muted);
            font-weight: 500;
            text-decoration: none;
            margin-bottom: 6px;
            transition: all 0.2s;
        }
        .sidebar-item:hover, .sidebar-item.active {
            background-color: #f1f5f9;
            color: var(--text-main);
        }

        /* Tabel Minimalis */
        .table {
            color: var(--text-main);
            white-space: nowrap;
            margin-bottom: 0;
        }
        .table > thead > tr > th {
            background-color: #f8fafc;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid #e2e8f0;
            padding: 12px 14px;
        }
        .table > tbody > tr > td {
            padding: 12px 14px;
            font-size: 0.875rem;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        /* Modal Styling */
        .modal-content {
            border: none;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.1);
        }
        .modal-header, .modal-footer {
            border-color: #f1f5f9;
            padding: 18px 20px;
        }
        .modal-body {
            padding: 20px;
        }
    </style>
</head>
<body>

    <!-- Navbar dengan Tombol Menu Sidebar (Kiri) -->
    <nav class="navbar navbar-expand px-4 sticky-top">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-light-subtle d-flex align-items-center justify-content-center p-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#leftSidebar" aria-controls="leftSidebar" style="width: 38px; height: 38px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-list" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z"/>
                </svg>
            </button>
            <span class="navbar-brand mb-0 h1">MTC.SYS</span>
        </div>
        <div class="navbar-nav ms-auto align-items-center">
            <span class="text-muted small d-none d-sm-inline">Admin Panel</span>
        </div>
    </nav>

    <!-- Offcanvas Sidebar Muncul dari Kiri -->
    <div class="offcanvas offcanvas-start" tabindex="-1" id="leftSidebar" aria-labelledby="leftSidebarLabel" style="width: 280px;">
        <div class="offcanvas-header border-0 pb-0">
            <h5 class="offcanvas-title fw-bold" id="leftSidebarLabel">MTC.SYS</h5>
            <button type="button" class="btn-close shadow-none" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column justify-content-between">
            <div>
                <p class="text-muted small mb-3 px-2">Menu Navigasi</p>
                <div class="list-unstyled">
                    <a href="/admin/sparepart" class="sidebar-item active">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-box-seam me-3" viewBox="0 0 16 16">
                            <path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5 8 5.961 14.154 3.5 8.186 1.113zM15 4.239l-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.838L1 4.239v7.923l6.5 2.6zM7.443.184a1.5 1.5 0 0 1 1.114 0l7.129 2.852A.5.5 0 0 1 16 3.5v8.662a1 1 0 0 1-.629.928l-7.185 2.874a.5.5 0 0 1-.372 0L.63 13.09a1 1 0 0 1-.63-.928V3.5a.5.5 0 0 1 .314-.464L7.443.184z"/>
                        </svg>
                        Sparepart Inventory
                    </a>
                    <a href="/admin/repair" class="sidebar-item">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-tools me-3" viewBox="0 0 16 16">
                            <path d="M1 0 0 1l2.2 3.081a1 1 0 0 0 .815.419h.07a1 1 0 0 1 .708.293l2.675 2.675-2.618 2.64A3 3 0 1 0 4 15.357l2.64-2.618 2.675 2.675a1 1 0 0 1 .293.707v.071a1 1 0 0 0 .419.815L15 16l1-1-3.5-3.5L12 10l-4-4 .5-1.5L9 3 1 0z"/>
                        </svg>
                        Repair Logs
                    </a>
                </div>
            </div>
            <div class="pt-3 border-top">
                <a href="/logout" class="sidebar-item text-danger">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-box-arrow-left me-3" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M6 12.5a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5h-8a.5.5 0 0 0-.5.5v2a.5.5 0 0 1-1 0v-2A1.5 1.5 0 0 1 6.5 2h8A1.5 1.5 0 0 1 16 3.5v9a1.5 1.5 0 0 1-1.5 1.5h-8A1.5 1.5 0 0 1 5 12.5v-2a.5.5 0 0 1 1 0v2z"/>
                        <path fill-rule="evenodd" d="M.146 8.354a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L1.707 7.5H10.5a.5.5 0 0 1 0 1H1.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3z"/>
                    </svg>
                    Logout
                </a>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container my-4">
        <div class="ios-card p-4">
            
            <!-- Header & Action Buttons -->
            <div class="row align-items-center justify-content-between mb-4 gy-3">
                <div class="col-12 col-md-4">
                    <h4 class="fw-bold mb-1" style="letter-spacing: -0.5px;">Sparepart Inventory</h4>
                    <p class="text-muted small mb-0">Kelola stok dan komponen mesin</p>
                </div>
                <div class="col-12 col-md-8 text-md-end">
                    <div class="d-flex flex-wrap justify-content-md-end gap-2">
                        <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#modalSparepart">+ Tambah Barang</button>
                        <button class="btn btn-light-subtle btn-sm" data-bs-toggle="modal" data-bs-target="#modalUpdateStok">⚡ Atur Stok</button>
                        <button class="btn btn-light-subtle btn-sm text-primary" data-bs-toggle="modal" data-bs-target="#modalImport">📥 Import</button>
                        <a href="/admin/sparepart/export" class="btn btn-light-subtle btn-sm text-success">Export</a>
                    </div>
                </div>
            </div>

            <!-- Search Bar Minimalis -->
            <form action="/admin/sparepart" method="GET" class="mb-4">
                <div class="input-group">
                    <input type="text" name="search" class="form-control" placeholder="Cari berdasarkan nama, kode, lokasi, atau type..." value="<%= search %>">
                    <% if(search) { %>
                        <a href="/admin/sparepart" class="btn btn-light-subtle text-danger border-start-0">Reset</a>
                    <% } %>
                    <button class="btn btn-dark px-4" type="submit">Cari</button>
                </div>
            </form>

            <!-- Table Section -->
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Kode</th>
                            <th>Nama Barang</th>
                            <th>Lokasi</th>
                            <th>Type</th>
                            <th>Stok</th>
                            <th>Masuk</th>
                            <th>Keluar</th>
                            <th>Fungsi</th>
                            <th class="text-end">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(spareparts.length === 0) { %>
                            <tr><td colspan="9" class="text-center py-4 text-muted">Tidak ada data sparepart ditemukan.</td></tr>
                        <% } %>
                        <% spareparts.forEach(s => { %>
                        <tr>
                            <td class="fw-semibold text-secondary"><%= s.kodeBarang %></td>
                            <td class="fw-bold text-dark"><%= s.namaBarang %></td>
                            <td><%= s.lokasiBarang || '-' %></td>
                            <td><%= s.typeBarang || '-' %></td>
                            <td>
                                <span class="badge bg-<%= s.stokBarang > 0 ? 'dark' : 'danger' %> px-2 py-1 rounded-pill fw-medium">
                                    <%= s.stokBarang %>
                                </span>
                            </td>
                            <td class="text-success fw-medium">+<%= s.barangMasuk %></td>
                            <td class="text-danger fw-medium">-<%= s.barangKeluar %></td>
                            <td><%= s.fungsiBarang || '-' %></td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group">
                                    <button class="ubah-stok-btn btn btn-light-subtle py-1 px-2" 
                                        data-id="<%= s._id %>" 
                                        data-nama="<%= s.namaBarang %>" 
                                        data-kode="<%= s.kodeBarang %>"
                                        data-bs-toggle="modal" data-bs-target="#modalUpdateStokDirect" title="Ubah Stok">
                                        ± Qty
                                    </button>
                                    <button class="hapus-btn btn btn-light-subtle text-danger py-1 px-2" 
                                        data-id="<%= s._id %>" 
                                        data-nama="<%= s.namaBarang %>" 
                                        data-kode="<%= s.kodeBarang %>"
                                        data-bs-toggle="modal" data-bs-target="#modalHapus" title="Hapus">
                                        Hapus
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal Tambah Barang -->
    <div class="modal fade" id="modalSparepart" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <form action="/admin/sparepart/save" method="POST" class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Tambah Sparepart Baru</h5>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label text-muted small fw-semibold">Nama Barang</label><input type="text" name="namaBarang" class="form-control" required></div>
                    <div class="mb-3"><label class="form-label text-muted small fw-semibold">Kode Barang</label><input type="text" name="kodeBarang" class="form-control" required></div>
                    <div class="mb-3"><label class="form-label text-muted small fw-semibold">Lokasi Barang</label><input type="text" name="lokasiBarang" class="form-control" placeholder="Contoh: Rak A-1"></div>
                    <div class="mb-3"><label class="form-label text-muted small fw-semibold">Type Barang</label><input type="text" name="typeBarang" class="form-control"></div>
                    <div class="mb-3"><label class="form-label text-muted small fw-semibold">Stok Awal</label><input type="number" name="stokBarang" class="form-control" value="0" min="0" required></div>
                    <div class="mb-0"><label class="form-label text-muted small fw-semibold">Fungsi Barang</label><input type="text" name="fungsiBarang" class="form-control"></div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="submit" class="btn btn-dark w-100 py-2">Simpan Sparepart</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Import Excel -->
    <div class="modal fade" id="modalImport" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <form action="/admin/sparepart/import" method="POST" enctype="multipart/form-data" class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Import Data Excel</h5>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3">Pilih file Excel (.xlsx / .xls) yang sesuai dengan format sistem.</p>
                    <div class="mb-0">
                        <input type="file" name="fileExcel" class="form-control" accept=".xlsx, .xls" required>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="submit" class="btn btn-dark w-100 py-2">Upload & Import</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Update Stok Universal -->
    <div class="modal fade" id="modalUpdateStok" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <form action="/admin/sparepart/update-stok" method="POST" class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Penyesuaian Stok</h5>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold">Cari Barang:</label>
                        <input type="text" id="globalSearchStock" class="form-control mb-2" placeholder="Ketik untuk memfilter pilihan..." onkeyup="filterStockOptions(this)">
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold">Pilih Sparepart</label>
                        <select name="sparepartId" id="globalStockSelect" class="form-select" size="4" required>
                            <% spareparts.forEach(s => { %>
                                <option value="<%= s._id %>" data-keywords="<%= (s.namaBarang + ' ' + s.kodeBarang + ' ' + (s.typeBarang || '') + ' ' + (s.lokasiBarang || '')).toLowerCase() %>">
                                    [<%= s.kodeBarang %>] <%= s.namaBarang %> (Stok: <%= s.stokBarang %>)
                                </option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold">Jenis Perubahan</label>
                        <select name="jenis" class="form-select" required>
                            <option value="tambah">Tambah Qty (Barang Masuk)</option>
                            <option value="kurang">Kurang Qty (Barang Keluar / Rusak)</option>
                        </select>
                    </div>
                    <div class="mb-0">
                        <label class="form-label text-muted small fw-semibold">Jumlah Qty</label>
                        <input type="number" name="jumlah" class="form-control" value="1" min="1" required>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="submit" class="btn btn-dark w-100 py-2">Proses Stok</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Update Stok Langsung (Per Baris) -->
    <div class="modal fade" id="modalUpdateStokDirect" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <form action="/admin/sparepart/update-stok" method="POST" class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Update Stok Item</h5>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3">Item: <strong id="directNamaBarang" class="text-dark"></strong></p>
                    <input type="hidden" name="sparepartId" id="directSparepartId">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold">Jenis Perubahan</label>
                        <select name="jenis" class="form-select" required>
                            <option value="tambah">Tambah Qty (Barang Masuk)</option>
                            <option value="kurang">Kurang Qty (Barang Keluar / Rusak)</option>
                        </select>
                    </div>
                    <div class="mb-0">
                        <label class="form-label text-muted small fw-semibold">Jumlah Qty</label>
                        <input type="number" name="jumlah" class="form-control" value="1" min="1" required>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="submit" class="btn btn-dark w-100 py-2">Simpan Perubahan</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Konfirmasi Hapus -->
    <div class="modal fade" id="modalHapus" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 360px;">
            <form id="formHapus" action="" method="POST" class="modal-content text-center p-3">
                <div class="modal-body">
                    <h5 class="fw-bold mb-2">Hapus Item?</h5>
                    <p class="text-muted small mb-4">Apakah Anda yakin ingin menghapus <strong id="hapusNamaBarang" class="text-dark"></strong>? Tindakan ini tidak dapat dibatalkan.</p>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-light-subtle w-50 py-2" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-danger w-50 py-2">Hapus</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Pop-up Modal untuk Error / Akses Ditolak (Ala iOS) -->
    <div class="modal fade" id="errorModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 340px;">
            <div class="modal-content border-0 p-3 text-center">
                <div class="modal-body">
                    <div class="mb-3 text-danger">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" class="bi bi-exclamation-circle-fill" viewBox="0 0 16 16">
                            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM8 4a.905.905 0 0 0-.9.995l.35 3.507a.552.552 0 0 0 1.1 0l.35-3.507A.905.905 0 0 0 8 4zm.002 6a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>
                        </svg>
                    </div>
                    <h5 class="fw-bold mb-2">Pemberitahuan</h5>
                    <p class="text-muted small mb-4"><%= typeof error !== 'undefined' ? error : '' %></p>
                    <button type="button" class="btn btn-dark w-100 py-2" data-bs-dismiss="modal">OK</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function filterStockOptions(inputElement) {
            const keyword = inputElement.value.toLowerCase();
            const select = document.getElementById('globalStockSelect');
            const options = select.getElementsByTagName('option');

            for (let i = 0; i < options.length; i++) {
                const keywords = options[i].getAttribute('data-keywords');
                if (keywords.includes(keyword)) {
                    options[i].style.display = "";
                } else {
                    options[i].style.display = "none";
                }
            }
        }

        document.querySelectorAll('.ubah-stok-btn').forEach(button => {
            button.addEventListener('click', function() {
                const id = this.getAttribute('data-id');
                const nama = this.getAttribute('data-nama');
                const kode = this.getAttribute('data-kode');

                document.getElementById('directSparepartId').value = id;
                document.getElementById('directNamaBarang').innerText = `[${kode}] ${nama}`;
            });
        });

        document.querySelectorAll('.hapus-btn').forEach(button => {
            button.addEventListener('click', function() {
                const id = this.getAttribute('data-id');
                const nama = this.getAttribute('data-nama');
                const kode = this.getAttribute('data-kode');

                document.getElementById('hapusNamaBarang').innerText = `[${kode}] ${nama}`;
                document.getElementById('formHapus').action = `/admin/sparepart/delete/${id}`;
            });
        });

        // Trigger Pop-up Modal jika ada Error/Akses Ditolak
        <% if(typeof error !== 'undefined' && error) { %>
        document.addEventListener("DOMContentLoaded", function() {
            new bootstrap.Modal(document.getElementById('errorModal')).show();
        });
        <% } %>
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
