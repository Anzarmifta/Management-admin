<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MTC.SYS — Sparepart</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --bg-body: #f8fafc;
            --card-bg: #ffffff;
            --border-color: #f1f5f9;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --radius-ios: 16px;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            -webkit-font-smoothing: antialiased;
        }

        .navbar {
            background: rgba(255, 255, 255, 0.85) !important;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid #e2e8f0;
        }
        .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.5px;
            color: #0f172a !important;
        }

        .ios-card {
            background: var(--card-bg);
            border: 1px solid #e2e8f0;
            border-radius: var(--radius-ios);
            box-shadow: 0 4px 20px rgba(15, 23, 42, 0.02);
        }

        .form-control, .form-select {
            border-radius: 10px;
            padding: 10px 14px;
            border: 1px solid #cbd5e1;
            background-color: #ffffff;
            font-size: 0.875rem;
            transition: all 0.2s ease;
        }

        .btn {
            border-radius: 10px;
            padding: 8px 14px;
            font-weight: 600;
            font-size: 0.85rem;
            transition: all 0.2s;
        }
        .btn-dark { background-color: #0f172a; border: none; }
        .btn-light-subtle { background-color: #f1f5f9; color: #334155; border: 1px solid #e2e8f0; }

        .offcanvas {
            border-top-right-radius: 24px;
            border-bottom-right-radius: 24px;
            border: none;
            box-shadow: 10px 0 40px rgba(15, 23, 42, 0.1);
        }

        .sidebar-item {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            border-radius: 12px;
            color: var(--text-muted);
            font-weight: 500;
            text-decoration: none;
            margin-bottom: 6px;
            transition: all 0.2s;
        }
        .sidebar-item:hover, .sidebar-item.active {
            background-color: #f1f5f9;
            color: var(--text-main);
        }

        .table { color: var(--text-main); white-space: nowrap; margin-bottom: 0; }
        .table > thead > tr > th {
            background-color: #f8fafc;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid #e2e8f0;
            padding: 12px 14px;
        }
        .table > tbody > tr > td { padding: 12px 14px; font-size: 0.875rem; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }

        .modal-content { border: none; border-radius: 20px; box-shadow: 0 20px 40px rgba(15, 23, 42, 0.1); }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand px-4 sticky-top">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-light-subtle d-flex align-items-center justify-content-center p-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#leftSidebar" style="width: 38px; height: 38px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-list" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z"/>
                </svg>
            </button>
            <span class="navbar-brand mb-0 h1">MTC.SYS</span>
        </div>
        <div class="navbar-nav ms-auto align-items-center">
            <span class="text-muted small d-none d-sm-inline">Admin Panel</span>
        </div>
    </nav>

    <div class="offcanvas offcanvas-start" tabindex="-1" id="leftSidebar">
        <div class="offcanvas-header border-0 pb-0">
            <h5 class="offcanvas-title fw-bold">MTC.SYS</h5>
            <button type="button" class="btn-close shadow-none" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column justify-content-between">
            <div>
                <p class="text-muted small mb-3 px-2">Menu Navigasi</p>
                <div class="list-unstyled">
                    <a href="/admin/sparepart" class="sidebar-item active">Sparepart Inventory</a>
                    <a href="/admin/repair" class="sidebar-item">Repair Logs</a>
                    <a href="/admin/users" class="sidebar-item">Manajemen Akun</a>
                </div>
            </div>
            <div class="pt-3 border-top">
                <a href="/logout" class="sidebar-item text-danger">Logout</a>
            </div>
        </div>
    </div>

    <div class="container my-4">
        <% if (locals.error && error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <div class="ios-card p-4">
            <div class="row align-items-center justify-content-between mb-4 gy-3">
                <div class="col-12 col-md-4">
                    <h4 class="fw-bold mb-1" style="letter-spacing: -0.5px;">Sparepart Inventory</h4>
                    <p class="text-muted small mb-0">Kelola stok dan komponen mesin</p>
                </div>
                <div class="col-12 col-md-8 text-md-end">
                    <div class="d-flex flex-wrap justify-content-md-end gap-2">
                        <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#modalSparepart">+ Tambah Barang</button>
                        <button class="btn btn-light-subtle btn-sm" data-bs-toggle="modal" data-bs-target="#modalUpdateStok">⚡ Atur Stok</button>
                        <button class="btn btn-light-subtle btn-sm text-primary" data-bs-toggle="modal" data-bs-target="#modalImport">📥 Import</button>
                        <a href="/admin/sparepart/export" class="btn btn-light-subtle btn-sm text-success">Export</a>
                    </div>
                </div>
            </div>

            <form action="/admin/sparepart" method="GET" class="mb-4">
                <div class="input-group">
                    <input type="text" name="search" class="form-control" placeholder="Cari barang..." value="<%= search %>">
                    <button class="btn btn-dark px-4" type="submit">Cari</button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Kode</th>
                            <th>Nama Barang</th>
                            <th>Lokasi</th>
                            <th>Stok</th>
                            <th>Masuk</th>
                            <th>Keluar</th>
                            <th class="text-end">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% spareparts.forEach(s => { %>
                        <tr>
                            <td class="fw-semibold text-secondary"><%= s.kodeBarang %></td>
                            <td class="fw-bold text-dark"><%= s.namaBarang %></td>
                            <td><%= s.lokasiBarang || '-' %></td>
                            <td><span class="badge bg-<%= s.stokBarang > 0 ? 'dark' : 'danger' %> rounded-pill"><%= s.stokBarang %></span></td>
                            <td class="text-success">+<%= s.barangMasuk %></td>
                            <td class="text-danger">-<%= s.barangKeluar %></td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <button class="riwayat-btn btn btn-light-subtle text-primary" 
                                        data-id="<%= s._id %>" 
                                        data-nama="<%= s.namaBarang %>" 
                                        data-kode="<%= s.kodeBarang %>"
                                        data-bs-toggle="modal" data-bs-target="#modalRiwayatPerbaikan">
                                        🛠️ Riwayat Teknisi
                                    </button>
                                    <button class="ubah-stok-btn btn btn-light-subtle" 
                                        data-id="<%= s._id %>" 
                                        data-nama="<%= s.namaBarang %>" 
                                        data-kode="<%= s.kodeBarang %>" 
                                        data-bs-toggle="modal" data-bs-target="#modalUpdateStokDirect">± Qty</button>
                                    <button class="hapus-btn btn btn-light-subtle text-danger" 
                                        data-id="<%= s._id %>" 
                                        data-nama="<%= s.namaBarang %>"
                                        data-bs-toggle="modal" data-bs-target="#modalHapus">Hapus</button>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- MODAL TAMBAH SPAREPART -->
    <div class="modal fade" id="modalSparepart" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form action="/admin/sparepart/save" method="POST">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold">Tambah Sparepart Baru</h5>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Kode Barang</label>
                            <input type="text" name="kodeBarang" class="form-control" required placeholder="Contoh: P001">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Nama Barang</label>
                            <input type="text" name="namaBarang" class="form-control" required placeholder="Contoh: Piston">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Lokasi Barang</label>
                            <input type="text" name="lokasiBarang" class="form-control" placeholder="Contoh: Rak A1">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Type Barang</label>
                            <input type="text" name="typeBarang" class="form-control" placeholder="Contoh: Heavy Duty">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Stok Awal</label>
                            <input type="number" name="stokBarang" class="form-control" value="0" min="0" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Fungsi Barang</label>
                            <textarea name="fungsiBarang" class="form-control" rows="2" placeholder="Fungsi komponen..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light-subtle" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-dark">Simpan Barang</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- MODAL ATUR STOK UMUM (TAMBAH / KURANG QTY) -->
    <div class="modal fade" id="modalUpdateStok" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form action="/admin/sparepart/update-stok" method="POST">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold">Atur Stok Sparepart</h5>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Pilih Sparepart</label>
                            <select name="sparepartId" class="form-select" required>
                                <option value="" disabled selected>-- Pilih Barang --</option>
                                <% spareparts.forEach(s => { %>
                                    <option value="<%= s._id %>">[<%= s.kodeBarang %>] <%= s.namaBarang %> (Stok: <%= s.stokBarang %>)</option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Jenis Perubahan</label>
                            <select name="jenis" class="form-select" required>
                                <option value="tambah">Tambah Stok (Masuk)</option>
                                <option value="kurang">Kurangi Stok (Keluar)</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Jumlah Qty</label>
                            <input type="number" name="jumlah" class="form-control" min="1" value="1" required>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light-subtle" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-dark">Proses Stok</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- MODAL ATUR STOK LANGSUNG DARI BARIS TABEL (± Qty) -->
    <div class="modal fade" id="modalUpdateStokDirect" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form action="/admin/sparepart/update-stok" method="POST">
                    <input type="hidden" name="sparepartId" id="directSparepartId">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold">Atur Stok: <span id="directSparepartName" class="text-primary"></span></h5>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Jenis Perubahan</label>
                            <select name="jenis" class="form-select" required>
                                <option value="tambah">Tambah Stok (Masuk)</option>
                                <option value="kurang">Kurangi Stok (Keluar)</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Jumlah Qty</label>
                            <input type="number" name="jumlah" class="form-control" min="1" value="1" required>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light-subtle" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-dark">Simpan Perubahan</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- MODAL IMPORT EXCEL -->
    <div class="modal fade" id="modalImport" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form action="/admin/sparepart/import" method="POST" enctype="multipart/form-data">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold">Import Data Sparepart (Excel)</h5>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Pilih File Excel (.xlsx)</label>
                            <input type="file" name="fileExcel" class="form-control" accept=".xlsx, .xls" required>
                            <div class="form-text small mt-1">Pastikan format kolom sesuai dengan template export Excel sistem.</div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light-subtle" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-dark">Upload & Import</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- MODAL HAPUS BARANG -->
    <div class="modal fade" id="modalHapus" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="formHapus" method="POST">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold text-danger">Konfirmasi Hapus</h5>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-0">Apakah Anda yakin ingin menghapus sparepart <strong id="hapusNamaBarang" class="text-dark"></strong> dari database?</p>
                    </div>
                    <div class="modal-footer border-0 pt-3">
                        <button type="button" class="btn btn-light-subtle" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-danger">Ya, Hapus</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Tracking / Riwayat Perbaikan -->
    <div class="modal fade" id="modalRiwayatPerbaikan" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <div>
                        <h5 class="modal-title fw-bold">Daftar Kegiatan Perbaikan (Berdasarkan Pemakaian Sparepart)</h5>
                        <p class="text-muted small mb-0" id="riwayatSubTitle">Sparepart: -</p>
                    </div>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="table-responsive border rounded-3" style="max-height: 450px; overflow-y: auto;">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Tanggal</th>
                                    <th>Shift</th>
                                    <th>Mesin</th>
                                    <th>Problem</th>
                                    <th>Analisa</th>
                                    <th>Perbaikan</th>
                                    <th>Qty Pakai</th>
                                    <th>PIC</th>
                                    <th>Jam</th>
                                    <th>Status</th>
                                    <th>Ket</th>
                                </tr>
                            </thead>
                            <tbody id="tabelBodyRiwayat">
                                <tr><td colspan="11" class="text-center py-3 text-muted">Memuat data log teknisi...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-dark w-100 py-2" data-bs-dismiss="modal">Tutup</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Logika Tombol ± Qty Direct pada Tabel
        document.querySelectorAll('.ubah-stok-btn').forEach(button => {
            button.addEventListener('click', function() {
                const id = this.getAttribute('data-id');
                const nama = this.getAttribute('data-nama');
                document.getElementById('directSparepartId').value = id;
                document.getElementById('directSparepartName').innerText = nama;
            });
        });

        // Logika Tombol Hapus pada Tabel
        document.querySelectorAll('.hapus-btn').forEach(button => {
            button.addEventListener('click', function() {
                const id = this.getAttribute('data-id');
                const nama = this.getAttribute('data-nama');
                document.getElementById('hapusNamaBarang').innerText = nama;
                document.getElementById('formHapus').action = `/admin/sparepart/delete/${id}`;
            });
        });

        // Logika Mengambil Data Riwayat Berdasarkan Pemakaian Sparepart
        document.querySelectorAll('.riwayat-btn').forEach(button => {
            button.addEventListener('click', function() {
                const id = this.getAttribute('data-id');
                const nama = this.getAttribute('data-nama');
                const kode = this.getAttribute('data-kode');

                document.getElementById('riwayatSubTitle').innerText = `Sparepart: [${kode}] ${nama}`;
                const tbody = document.getElementById('tabelBodyRiwayat');
                tbody.innerHTML = `<tr><td colspan="11" class="text-center py-3 text-muted">Memuat data log teknisi...</td></tr>`;

                fetch(`/admin/sparepart/repair-history/${id}`)
                    .then(response => response.json())
                    .then(data => {
                        if (!data || data.length === 0) {
                            tbody.innerHTML = `<tr><td colspan="11" class="text-center py-4 text-muted">Belum ada aktivitas perbaikan yang menggunakan sparepart ini.</td></tr>`;
                            return;
                        }
                        let rows = '';
                        data.forEach(item => {
                            const badgeColor = item.status === 'ok' ? 'success' : (item.status === 'progress' ? 'warning' : 'danger');
                            rows += `
                                <tr>
                                    <td class="fw-semibold text-secondary">${item.tanggal ? item.tanggal.split('T')[0] : '-'}</td>
                                    <td>${item.shift || '-'}</td>
                                    <td class="fw-bold text-dark">${item.namaMesin || '-'}</td>
                                    <td>${item.problem || '-'}</td>
                                    <td>${item.analisaPenyebab || '-'}</td>
                                    <td>${item.caraPerbaikan || '-'}</td>
                                    <td><span class="badge bg-danger">-${item.jumlahPakai || 1}</span></td>
                                    <td>${item.pic || '-'}</td>
                                    <td>${item.jamMulai || '-'} - ${item.jamSelesai || '-'}</td>
                                    <td>
                                        <span class="badge bg-${badgeColor} px-2 py-1 rounded-pill fw-medium">
                                            ${(item.status || 'open').toUpperCase()}
                                        </span>
                                    </td>
                                    <td>${item.keterangan || '-'}</td>
                                </tr>`;
                        });
                        tbody.innerHTML = rows;
                    })
                    .catch(err => {
                        tbody.innerHTML = `<tr><td colspan="11" class="text-center py-3 text-danger">Gagal mengambil data dari server.</td></tr>`;
                    });
            });
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
