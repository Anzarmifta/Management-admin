<!DOCTYPE html>
<html>
<head>
    <title>Cari Sparepart - Teknisi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-secondary px-4 navbar-expand">
        <span class="navbar-brand mb-0 h1">Teknisi Panel</span>
        <div class="navbar-nav ms-auto">
            <a href="/teknisi/dashboard" class="nav-link">Input Perbaikan</a>
            <a href="/teknisi/sparepart" class="nav-link active fw-bold">Cari Sparepart</a>
            <a href="/logout" class="btn btn-outline-light btn-sm ms-3">Logout</a>
        </div>
    </nav>

    <div class="container my-4">
        <div class="card p-4 shadow-sm mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4>Pencarian Data Sparepart</h4>
            </div>

            <form action="/teknisi/sparepart" method="GET" class="input-group mb-3">
                <input type="text" name="search" class="form-control" placeholder="Cari berdasarkan nama, kode, lokasi, type, atau fungsi..." value="<%= search %>">
                <button class="btn btn-outline-secondary" type="submit">Cari</button>
                <% if(search) { %>
                    <a href="/teknisi/sparepart" class="btn btn-outline-danger">Reset</a>
                <% } %>
            </form>

            <div class="table-responsive">
                <table class="table table-bordered table-striped align-middle">
                    <thead class="table-secondary">
                        <tr>
                            <th>Kode Barang</th>
                            <th>Nama Barang</th>
                            <th>Lokasi</th>
                            <th>Type</th>
                            <th>Stok Tersedia</th>
                            <th>Fungsi Barang</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(spareparts.length === 0) { %>
                            <tr><td colspan="6" class="text-center">Tidak ada sparepart yang ditemukan.</td></tr>
                        <% } %>
                        <% spareparts.forEach(s => { %>
                        <tr>
                            <td><%= s.kodeBarang %></td>
                            <td><%= s.namaBarang %></td>
                            <td><%= s.lokasiBarang || '-' %></td>
                            <td><%= s.typeBarang || '-' %></td>
                            <td>
                                <span class="badge bg-<%= s.stokBarang > 0 ? 'success' : 'danger' %>">
                                    <%= s.stokBarang %>
                                </span>
                            </td>
                            <td><%= s.fungsiBarang || '-' %></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
